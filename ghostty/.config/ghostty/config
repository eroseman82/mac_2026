background-opacity = .93
theme = Catppuccin Frappe
background-blur-radius = 95
window-decoration = false
macos-titlebar-style = hidden
auto-update = download

# Keybinds
keybind = ctrl+a>n=new_window
keybind = ctrl+a>a=select_all
keybind = ctrl+a>s=new_split:down
keybind = ctrl+a>o=open_config
keybind = ctrl+k=scroll_page_up 
keybind = ctrl+a>r=reload_config
keybind = ctrl+a>s=scroll_to_selection
keybind = ctrl+a>c=open_config

# ctrl+shift+,
keybind = ctrl+j=scroll_page_down
keybind = ctrl+k=scroll_page_up
keybind = ctrl+shift+up=scroll_page_up
keybind = ctrl+shift+down=scroll_page_down
keybind = shift+enter=text:\x1b\r

# Hyper+1..9 layer (right_cmd → F13..F21 via Karabiner).
# Ghostty doesn't emit anything for F13+ by default — send standard xterm sequences.
keybind = f13=text:\x1b[1;2P
keybind = f14=text:\x1b[1;2Q
keybind = f15=text:\x1b[1;2R
keybind = f16=text:\x1b[1;2S
keybind = f17=text:\x1b[15;2~
keybind = f18=text:\x1b[17;2~
keybind = f19=text:\x1b[18;2~
keybind = f20=text:\x1b[19;2~
keybind = f21=text:\x1b[20;2~
